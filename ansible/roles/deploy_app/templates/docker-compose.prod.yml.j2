version: '3.9'

services:
  db:
    image: postgres:15-alpine
    container_name: metoffice_weather-db
    restart: always
    env_file:
      - /etc/metoffice_weather/.env
    environment:
      POSTGRES_DB: metoffice_db
      POSTGRES_USER: weather
      POSTGRES_PASSWORD: mypassword
      PGDATA: /var/lib/postgresql/data/pgdata
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - metoffice_weather_net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $${POSTGRES_USER} -d $${POSTGRES_DB}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s

  redis:
    image: redis:alpine
    container_name: metoffice_weather-redis
    restart: always
    networks:
      - metoffice_weather_net
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  metoffice_weather:
    image: shailendershrma/metoffice_weather:{{ image_tag }}
    container_name: metoffice_weather
    command: gunicorn metoffice_weather.wsgi:application --bind 0.0.0.0:8000 --workers 3 --timeout 120
    env_file:
      - /etc/metoffice_weather/.env
    volumes:
      - static_volume:/usr/src/metoffice_weather/staticfiles:ro
      - media_volume:/usr/src/metoffice_weather/media:ro
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    restart: always
    networks:
      - metoffice_weather_net
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/api/meta/"]   # Change endpoint if needed
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

  worker:
    image: shailendershrma/metoffice_weather:{{ image_tag }}
    container_name: metoffice_weather-worker
    command: celery -A metoffice_weather worker --loglevel=info
    env_file:
      - /etc/metoffice_weather/.env
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    restart: always
    networks:
      - metoffice_weather_net

  beat:
    image: shailendershrma/metoffice_weather:{{ image_tag }}
    container_name: metoffice_weather-beat
    command: celery -A metoffice_weather beat --loglevel=info
    env_file:
      - /etc/metoffice_weather/.env
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    restart: always
    networks:
      - metoffice_weather_net

  nginx:
    image: nginx:alpine
    container_name: metoffice_weather-nginx
    ports:
      - "80:80"
    volumes:
      - /srv/metoffice_weather/nginx.conf:/etc/nginx/nginx.conf:ro
      - static_volume:/usr/src/metoffice_weather/staticfiles:ro
      - media_volume:/usr/src/metoffice_weather/media:ro
    depends_on:
      metoffice_weather:
        condition: service_healthy
    restart: always
    networks:
      - metoffice_weather_net

volumes:
  static_volume:
  media_volume:
  postgres_data:

networks:
  metoffice_weather_net:
    driver: bridge